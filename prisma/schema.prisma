generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Game {
  id              String   @id @default(cuid())
  title           String
  platform        String   // steam | nintendo | playstation | other
  steamAppId      String?  @unique
  externalId      String?  // platform-specific ID for PSN/Nintendo
  playtimeMinutes Int      @default(0)
  recentPlaytimeMinutes Int?
  recentPlaytimeSource String?
  recentPlaytimeUpdatedAt DateTime?
  userRating      Float?   // 0~10, step 0.5
  reviewRichText  String?  // JSON string from Tiptap
  coverUrl        String?
  tags            String?  // comma-separated for simplicity in V1
  status          String   @default("played") // played | playing | backlog | dropped
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  logs            GameLog[]
  listItems       GameListItem[]

  @@unique([platform, externalId])
  @@index([platform])
  @@index([status])
  @@index([userRating])
  @@index([playtimeMinutes])
  @@index([recentPlaytimeMinutes])
}

model GameLog {
  id        String   @id @default(cuid())
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  playedAt  DateTime @default(now())
  minutes   Int      @default(0)
  note      String?
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gameId])
  @@index([playedAt])
}

model GameList {
  id          String         @id @default(cuid())
  title       String
  description String?
  ranked      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  items       GameListItem[]
}

model GameListItem {
  id        String   @id @default(cuid())
  listId    String
  list      GameList @relation(fields: [listId], references: [id], onDelete: Cascade)
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  position  Int      @default(0)
  note      String?
  createdAt DateTime @default(now())

  @@unique([listId, gameId])
  @@index([listId, position])
  @@index([gameId])
}

model PlatformAccount {
  id               String    @id @default(cuid())
  platform         String    @unique // steam | nintendo | playstation
  accountId        String
  apiKey           String?
  credentialJson   String?
  credentialStatus String    @default("unknown") // unknown | valid | invalid | needs_refresh
  syncStatus       String    @default("idle") // idle | syncing | error
  tokenExpiresAt   DateTime?
  lastCheckedAt    DateTime?
  lastError        String?
  lastSyncAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SyncJob {
  id         String   @id @default(cuid())
  platform   String
  status     String   @default("running") // running | success | failed
  syncedCount Int     @default(0)
  updatedCount Int    @default(0)
  failedCount  Int    @default(0)
  message    String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
}
