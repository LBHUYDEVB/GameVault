# Required. Used by the built-in HTTP Basic Auth protection.
APP_USERNAME=gamevault
APP_PASSWORD=

# Host port and bind address.
GAMEVAULT_PORT=3000
GAMEVAULT_BIND=0.0.0.0

# Optional outbound proxy. On Linux Docker, host.docker.internal points to the host.
# HTTPS_PROXY=http://host.docker.internal:7890
# HTTP_PROXY=http://host.docker.internal:7890
# ALL_PROXY=http://host.docker.internal:7890
